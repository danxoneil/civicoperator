# monday.com Configuration
# Get your API key from: https://your-org.monday.com/admin/integrations/api
MONDAY_API_KEY=your_monday_api_key_here
MONDAY_BOARD_ID=your_board_id_here

# monday.com Column IDs (customize based on your board structure)
MONDAY_PHONE_COLUMN_ID=phone
MONDAY_STATUS_COLUMN_ID=status
MONDAY_OPT_IN_COLUMN_ID=opt_in

# Twilio Configuration
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Message Configuration
# Use placeholders like {name}, {first_name}, or any {column_id} from your board
MESSAGE_TEMPLATE=Hi {name}, this is a test message from our organization!

# Operation Settings
DRY_RUN=true                      # Set to 'false' to actually send messages
RATE_LIMIT_DELAY=1.0              # Delay in seconds between messages (Twilio allows 1 msg/sec)
UPDATE_MONDAY_STATUS=true         # Update status column in monday.com after sending
